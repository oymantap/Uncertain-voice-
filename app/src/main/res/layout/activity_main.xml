<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0221"> <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="UNCERTAIN VOICE"
            android:textColor="#00FFFF"
            android:textSize="28sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:layout_gravity="center"
            android:shadowColor="#00FFFF"
            android:shadowDx="0"
            android:shadowDy="0"
            android:shadowRadius="10" />

        <View
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="#FF00FF"
            android:layout_marginVertical="15dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/cyber_panel"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ENGINE STATUS: READY"
                android:textColor="#39FF14"
                android:textSize="12sp"
                android:layout_marginBottom="10dp" />

            <Button
                android:id="@+id/btn_start_service"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="ACTIVATE FLOATING NODE"
                android:backgroundTint="#FF00FF"
                android:textColor="#FFFFFF" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CONNECT WITH CREATOR"
            android:textColor="#FFFFFF"
            android:layout_marginTop="25dp"
            android:layout_marginBottom="10dp" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <androidx.cardview.widget.CardView
                    android:layout_width="150dp"
                    android:layout_height="80dp"
                    android:layout_margin="5dp"
                    android:backgroundTint="#25D366">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:text="TIKTOK\n@rycl_uncertain"
                        android:gravity="center"
                        android:textColor="#000"
                        android:textStyle="bold" />
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="150dp"
                    android:layout_height="80dp"
                    android:layout_margin="5dp"
                    android:backgroundTint="#FF0000">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:text="YOUTUBE\nSUBSCRIBE"
                        android:gravity="center"
                        android:textColor="#FFF"
                        android:textStyle="bold" />
                </androidx.cardview.widget.CardView>
            </LinearLayout>
        </HorizontalScrollView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="25dp"
            android:padding="15dp"
            android:background="#1A1A1A">
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="HOW TO USE:\n1. Klik Activate di atas.\n2. Berikan izin Overlay.\n3. Klik icon melayang untuk rekam suara.\n4. Pilih filter neon untuk hasil maksimal."
                android:textColor="#AAAAAA"
                android:lineSpacingExtra="5dp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
          

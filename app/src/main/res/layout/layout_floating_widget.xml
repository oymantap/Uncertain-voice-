<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root_container"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">

    <ImageView
        android:id="@+id/collapsed_iv"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:background="@drawable/neon_circle"
        android:padding="10dp"
        android:src="@drawable/logo_kamu" />

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@drawable/cyber_panel"
    android:padding="8dp">

    <ImageView
        android:id="@+id/collapsed_iv"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:background="@drawable/neon_circle"
        android:src="@drawable/logo_kamu" />

    <LinearLayout
        android:id="@+id/menu_layout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:gravity="center_vertical">

        <View
            android:layout_width="40dp"
            android:layout_height="20dp"
            android:layout_marginHorizontal="10dp"
            android:background="@drawable/wave_placeholder" />

        <ImageButton
            android:id="@+id/btn_record"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:src="@android:drawable/ic_btn_speak_now"
            android:background="?android:attr/selectableItemBackground"/>

        <Spinner
            android:id="@+id/spinner_pitch"
            android:layout_width="100dp"
            android:layout_height="wrap_content"
            android:entries="@array/voice_options" />

        <ImageButton
            android:id="@+id/btn_close"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:background="?android:attr/selectableItemBackground"/>
    </LinearLayout>
</RelativeLayout>

